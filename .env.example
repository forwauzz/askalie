# Copy to .env and fill in. Only needed for live runs; the test suite never reads these.
# Leave ANTHROPIC_API_KEY empty to bill against your Claude subscription seat
# (Claude Code login) instead of pay-per-token API billing.
ANTHROPIC_API_KEY=
ASK_ALIE_WORKSPACE=workspace
# Path to tesseract.exe if it is not on PATH (needs fra+eng language packs).
TESSERACT_CMD=
# Model tiers: cheap tier for high-volume readers, capable tier for judgment agents.
ASK_ALIE_READER_MODEL=haiku
ASK_ALIE_AGENT_MODEL=sonnet
